# Secret shared between Supabase edge functions and this server.
# Generate a random 32+ char string and set the same value in both places:
#   supabase secrets set MUSIC_BOT_SERVER_SECRET=<value>
BOT_SERVER_SECRET=your-random-32-char-secret-here

# The public URL of your NrithyaHolics frontend (no trailing slash).
# Puppeteer navigates to this to open the music-bot page.
APP_URL=https://online.nrithyaholics.in

# Port the Express server listens on (Railway sets PORT automatically).
PORT=3000
